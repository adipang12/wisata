# Salin file ini menjadi .env lalu isi nilainya
# File .env TIDAK boleh di-commit ke GitHub

# Database
DB_PASSWORD=ganti_password_kuat_disini
MYSQL_ROOT_PASSWORD=ganti_root_password_disini

# Google Maps API Key (dari console.cloud.google.com)
GOOGLE_MAPS_API_KEY=

# Groq AI API Key (dari console.groq.com - GRATIS 6000 req/hari)
GROQ_API_KEY=
